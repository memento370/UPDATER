<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Updater.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:local="clr-namespace:Updater" 
        
        
        xmlns:converters="clr-namespace:Updater.UtillsClasses"
        
        xmlns:tb="http://www.hardcodet.net/taskbar" 
        xmlns:av="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        Title="VLGame" 
        Height="537" 
        Width="1140" 
        AllowsTransparency="True" 
        WindowStyle="None" 
        WindowStartupLocation="CenterScreen" 
        Icon="../l2.ico" 
        Background="{x:Null}" 
        ContentRendered="Window_ContentRendered">
    <FrameworkElement.Resources>


        <ResourceDictionary />


    </FrameworkElement.Resources>
    <FrameworkElement.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource OpenAnimation}" />
        </EventTrigger>
    </FrameworkElement.Triggers>
    <Grid Name="grid" Width="1140" Height="537" MouseDown="Grid_MouseDown">
        <Rectangle Name="BackGround" Width="1140" Height="537">
            <Shape.Fill>
                <ImageBrush ImageSource="pictures/backabsolute.png" />
            </Shape.Fill>
        </Rectangle>
        <Rectangle Name="BackGroundEng" Width="1140" Height="537">
            <Shape.Fill>
                <ImageBrush ImageSource="pictures/backabsolute.png" />
            </Shape.Fill>
        </Rectangle>
        <Button Name="Cancel" Content="ОТМЕНА" Margin="850,500,0,0" VerticalAlignment="Top" Cursor="Hand" Template="{DynamicResource ButtonControlTemplate}" FontSize="18" HorizontalAlignment="Left" Command="{Binding CancelCommand}" ></Button>
        <Button Name="QuickCheck" Content="БЫСТРАЯ ПРОВЕРКА" HorizontalAlignment="Left" Margin="850,400,0,0" Template="{DynamicResource ButtonControlTemplate}" VerticalAlignment="Top" Cursor="Hand" FontSize="18.667" Command="{Binding QuickCommand}" />
        <Button Name="FullCheck" Content="ОБНОВИТЬ" Margin="850,450,0,0" VerticalAlignment="Top" Cursor="Hand" Template="{DynamicResource ButtonControlTemplate}" FontSize="18.667" HorizontalAlignment="Left" Command="{Binding FullCommand}" ></Button>
        <Button Name="StartButton" Content="" HorizontalAlignment="Left" Margin="2,400,0,0" VerticalAlignment="Top" Template="{DynamicResource StartButtonPictureTemplate}" FontSize="24" Cursor="Hand" Command="{Binding StartCommand}" Foreground="{x:Null}" BorderBrush="{x:Null}" Width="140" Height="140" Background="{x:Null}" />
        <ProgressBar Name="FileProgress" HorizontalAlignment="Left" Height="11" Margin="160,470,0,0" VerticalAlignment="Top" Width="680" Value="{Binding ProgressFile}" Maximum="{Binding MaxProgressFile}" Background="{x:Null}" BorderBrush="{x:Null}">
            <Control.Foreground>
                <ImageBrush ImageSource="pictures/progressred.png"/>
            </Control.Foreground>
        </ProgressBar>
        <ProgressBar Name="FullProgress" HorizontalAlignment="Left" Height="11" Margin="160,500,0,0" VerticalAlignment="Top" Width="680" Value="{Binding ProgressFull}" Maximum="{Binding MaxProgressFull}" BorderBrush="{x:Null}" Background="{x:Null}">
            <Control.Foreground>
                <ImageBrush ImageSource="pictures/progressblue.png" />
            </Control.Foreground>
        </ProgressBar>

        <Label Name="Information" HorizontalContentAlignment="Left" HorizontalAlignment="Left" Margin="180,400,0,0" VerticalAlignment="Top" Height="30" Width="393" FontFamily="{StaticResource HombreItalic}" Foreground="#CFEEE8E0" FontWeight="Medium" FontSize="15" Content="{Binding Info.GetLocStr}" />
        <!-- <Label FontFamily="{StaticResource HombreItalic}" Name="FullSize" HorizontalContentAlignment="Right" HorizontalAlignment="Left" Margin="0,0,0,0" VerticalAlignment="Top" Width="88" /> -->
        <Label FontFamily="{StaticResource HombreItalic}" Name="Speed" HorizontalAlignment="Left" Margin="180,440,0,0" VerticalAlignment="Top" Width="146" Foreground="#FFA5DF43" Content="{Binding DownloadSpeed}" Height="28" FontSize="16" FontWeight="Bold" />
        <Label FontFamily="{StaticResource HombreItalic}" Name="Download_Information" HorizontalContentAlignment="Left" HorizontalAlignment="Left" Margin="180,420,0,0" VerticalAlignment="Top" Height="30" Width="393" Foreground="#FFFAD9A6" FontWeight="Medium" FontSize="15" Content="{Binding DownloadInfo.GetLocStr}" />
       
        <!-- <TextBlock Name="ProcFile" TextAlignment="Right" HorizontalAlignment="Left" Margin="281,436,0,0" VerticalAlignment="Top" Height="25" Width="47" />
        <TextBlock Name="ProcFull" TextAlignment="Right" HorizontalAlignment="Left" Margin="364,436,0,0" VerticalAlignment="Top" Height="25" Width="47" /> -->
        <Grid Name="LangGrid" HorizontalAlignment="Left" Height="49" Margin="818,4,0,0" VerticalAlignment="Top" Width="100" Visibility="Hidden">
            <TextBlock Name="LangTitle" TextAlignment="Center" HorizontalAlignment="Left" Height="22.667" TextWrapping="Wrap" Text="ВЫБЕРИ ЯЗЫК" VerticalAlignment="Top" Width="187.334" FontFamily="Arial" FontWeight="Bold" Foreground="#FFF7F7F7" Margin="-38.667,0,-40.667,0" Visibility="Hidden" />
            <RadioButton Name="RusRadio" Content="Rus" VerticalAlignment="Top" Cursor="Hand" Template="{DynamicResource RadioLang}" Height="37" Margin="7,2,0,0" HorizontalAlignment="Left" Width="34" Checked="radioButton_RUS_Checked">
                <Control.Background>
                    <ImageBrush ImageSource="pictures/rus.png" />
                </Control.Background>
            </RadioButton>
            <RadioButton Name="EngRadio" Content="Eng" HorizontalAlignment="Left" VerticalAlignment="Top" Height="37" Width="34" Cursor="Hand" Template="{DynamicResource RadioLang}" Margin="46,2,0,0" Checked="radioButton_ENG_Checked">
                <Control.Background>
                    <ImageBrush ImageSource="pictures/eng.png" />
                </Control.Background>
            </RadioButton>
        </Grid>       
        <Button Name="Main" Content="Главная" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Top" Width="auto" Height="auto" Template="{DynamicResource AccountTemplate}"  Cursor="Hand" Click="Site_Click"></Button>
        <Button Name="Register" Content="Регистрация" HorizontalAlignment="Left" Margin="120,0,0,0" VerticalAlignment="Top" Width="auto" Template="{DynamicResource AccountTemplate}" Cursor="Hand" Height="auto" Click="Reg_Click"></Button>
        <Button Name="About" Content="Об игре" HorizontalAlignment="Left" Margin="270,0,0,0" VerticalAlignment="Top" Width="auto" Template="{DynamicResource AccountTemplate}" Cursor="Hand" Height="auto" Click="About_Click"></Button>
        <Button Name="BaseInfo" Content="База знаний" HorizontalAlignment="Left" Margin="380,0,0,0" VerticalAlignment="Top" Width="auto" Template="{DynamicResource AccountTemplate}" Cursor="Hand" Height="auto" Click="Base_Info_Click"></Button>
        <Button Name="Cabinet" Content="Кабинет" HorizontalAlignment="Left" Margin="530,0,0,0" VerticalAlignment="Top" Width="auto" Template="{DynamicResource AccountTemplate}" Cursor="Hand" Height="auto" Click="Cabinet_Click"></Button>

        <!-- <Button Name="Tray" Content="Tray" HorizontalAlignment="Left" Margin="1009,64,0,0" VerticalAlignment="Top" Width="16" Cursor="Hand" Height="16" Template="{DynamicResource SimpleBackgroundTemplate}" Background="#00FFFFFF" Command="{Binding TrayCommand}" /> -->
        <Button Name="Exit" Content="Exit" HorizontalAlignment="Left" Margin="1105,10,10,0" VerticalAlignment="Top" Width="25" Cursor="Hand" Height="25" Template="{DynamicResource SimpleBackgroundTemplate}" Command="{Binding ExitCommand}" >
            <av:Button.Background>
                <av:ImageBrush ImageSource="pictures/close.png"/>
            </av:Button.Background>
        </Button>
        <Button Name="FileButton" Content="Tray" HorizontalAlignment="Left" Margin="476.584,52,0,0" VerticalAlignment="Top" Width="34" Cursor="Hand" Height="34" Template="{DynamicResource FileButton}" Visibility="Hidden" IsEnabled="{Binding IsSearching}" Background="{x:Null}" Click="FileButton_Click" />
        <TextBlock Name="PathText" HorizontalAlignment="Left" Margin="348,57,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="124" Foreground="#FFD48A12" FontSize="10" TextTrimming="CharacterEllipsis" Height="13" Visibility="Hidden" Text="{Binding SavePath}" />
        <!-- <Button Name="Donate" Content="ПОЖЕРТВОВАНИЯ" HorizontalAlignment="Left" Margin="468,85,0,0" VerticalAlignment="Top" Width="148" Template="{DynamicResource AccountTemplate}" Cursor="Hand" Height="29" Click="Donate_Click">
            <Control.Background>
                <ImageBrush ImageSource="pictures/vector.png" />
            </Control.Background>
        </Button> -->
        <Button Name="Supp" Content="Поддержка" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="109" Template="{DynamicResource SuppTemplate}" Cursor="Hand" Height="30" Visibility="Hidden" Click="Supp_Click">
            <Control.Background>
                <ImageBrush ImageSource="pictures/shaiba.png" />
            </Control.Background>
        </Button>
    </Grid>
</Window>